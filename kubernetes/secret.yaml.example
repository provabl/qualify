# Copy to secret.yaml, fill in values, then apply.
# NEVER commit secret.yaml to source control.
# Generate JWT_SECRET with: openssl rand -hex 32
# Encode values with: echo -n 'value' | base64

apiVersion: v1
kind: Secret
metadata:
  name: qualify-secrets
  namespace: qualify
  labels:
    app.kubernetes.io/name: qualify
    app.kubernetes.io/component: backend
type: Opaque
data:
  # echo -n 'your-db-password' | base64
  DB_PASSWORD: <base64-encoded-password>

  # echo -n 'your-32+-byte-jwt-secret' | base64
  JWT_SECRET: <base64-encoded-jwt-secret>

  # echo -n 'your-license-key-from-provabl.co' | base64
  # Leave empty (omit key) for community tier
  LICENSE_KEY: <base64-encoded-license-key>
