# qualify deployment environment variables
# Copy to .env and fill in values. Never commit .env to source control.

# ── Database ────────────────────────────────────────────────────────────────
DB_PASSWORD=change-me-to-a-strong-password

# ── Authentication ──────────────────────────────────────────────────────────
# Dev mode: set to true for local development only (bypasses JWT checks)
AUTH_DEV_MODE=true
AUTH_DEV_USER_ID=00000000-0000-0000-0000-000000000001
AUTH_DEV_EMAIL=dev@example.edu

# Production: set AUTH_DEV_MODE=false and generate a JWT_SECRET
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── License ─────────────────────────────────────────────────────────────────
# Leave empty for community tier (open-source modules only, no SSO)
# Get a license key at https://provabl.co
LICENSE_KEY=

# ── Optional overrides ───────────────────────────────────────────────────────
# VERSION=0.1.1
# LICENSE_CACHE_TTL=24h
# JWT_EXPIRY=24h
